*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Exception: Keep dependency JARs in WEB-INF/lib
!src/main/webapp/WEB-INF/lib/*.jar

# Local environment files
.env
.env.local

# Database files
*.db
*.sqlite

# Build output
*.class
bin/
gen/
out/

# Maven wrapper
.mvn/
!.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
gradle/
!gradle-wrapper.jar

# Node modules (if using frontend tools)
node_modules/
npm-debug.log
yarn-error.log

# Railway.app files (keep railway.json)
!railway.json